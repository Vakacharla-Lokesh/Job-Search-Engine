{
  "name": "server",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "setup-index": "bun run scripts/setup-index.ts",
    "ingest": "bun run scripts/ingest.ts",
    "ingest:remotive": "bun run scripts/ingest.ts --source remotive",
    "ingest:hn": "bun run scripts/ingest.ts --source hn"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.3.4",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  }
}
